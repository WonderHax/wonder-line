{
  "compilerOptions": {
    /* 出力設定 */
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": ".",

    /* Node.js 用 */
    "lib": ["ES2020"],
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,

    /* 型定義の出力 */
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    /* 厳格モード（推奨） */
    "strict": true,

    /* ESM 用 */
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "isolatedModules": false,

    /* その他 */
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false
  },

  /* ビルド対象 */
  "include": ["linejs/**/*"]
}